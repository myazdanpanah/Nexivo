# =============================================
# Nexivo — Environment Variables
# =============================================
# Copy this file to backend/.env and fill in values.
# cp .env.example backend/.env

# --- Django ---
# Secret key for cryptographic signing (change in production!)
SECRET_KEY=django-insecure-change-me-in-production

# Enable debug mode (0 = off, 1 = on)
DEBUG=1

# --- PostgreSQL ---
POSTGRES_DB=nexivo
POSTGRES_USER=nexivo_user
POSTGRES_PASSWORD=nexivo_pass
DB_HOST=localhost
DB_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Apache Superset ---
SUPERSET_API_URL=http://superset:8088/api/v1
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin
SUPERSET_SECRET_KEY=nexivo-superset-secret-key-change-me
