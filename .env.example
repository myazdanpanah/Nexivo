# Nexivo Environment Configuration
# Copy to backend/.env and adjust values as needed

# Django
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=1

# PostgreSQL
POSTGRES_DB=nexivo
POSTGRES_USER=nexivo_user
POSTGRES_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Superset
SUPERSET_API_URL=http://localhost:8088/api/v1
SUPERSET_SECRET_KEY=your-superset-secret-here
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin
